#!/usr/bin/env sh

# ── Scripting Addition (requires SIP partially disabled) ───
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"

# Retry SA load on cold boot (Dock may not be ready yet)
for i in $(seq 1 10); do
  if sudo yabai --load-sa 2>/dev/null; then
    break
  fi
  sleep 0.5
done

# ── Global Settings ────────────────────────────────────────
yabai -m config layout                       bsp
yabai -m config window_placement             second_child
yabai -m config auto_balance                 on
yabai -m config split_ratio                  0.60

# ── Mouse ──────────────────────────────────────────────────
yabai -m config mouse_follows_focus          on
yabai -m config mouse_modifier               alt
yabai -m config mouse_action1                move
yabai -m config mouse_action2                resize
yabai -m config mouse_drop_action            swap

# ── Gaps & Padding ─────────────────────────────────────────
# external_bar reserves space for sketchybar on the main display
yabai -m config external_bar                 all:30:0
yabai -m config top_padding                  15
yabai -m config bottom_padding               15
yabai -m config left_padding                 15
yabai -m config right_padding                15
yabai -m config window_gap                   15

# Space 1 (terminals): tighter gaps
yabai -m config --space 1 top_padding        15
yabai -m config --space 1 bottom_padding     5
yabai -m config --space 1 left_padding       5
yabai -m config --space 1 right_padding      5
yabai -m config --space 1 window_gap         5

# ── Window Rules ───────────────────────────────────────────
yabai -m rule --add app="Ghostty"            space=1
yabai -m rule --add app="Google Chrome"      space=2
yabai -m rule --add app="Discord"            space=3
yabai -m rule --add app="Figma"              space=4
yabai -m rule --add app="Simulator"          space=4

# Floating apps
yabai -m rule --add app="Finder"             manage=off
yabai -m rule --add app="System Settings"    manage=off
yabai -m rule --add app="Calculator"         manage=off
yabai -m rule --add app="Archive Utility"    manage=off
yabai -m rule --add app="Activity Monitor"   manage=off

# ── Sketchybar Signals ────────────────────────────────────
yabai -m signal --add event=space_changed \
    action="sketchybar --trigger space_change FOCUSED_SPACE=\$YABAI_SPACE_ID"
yabai -m signal --add event=window_focused \
    action="sketchybar --trigger window_focus"
yabai -m signal --add event=window_created \
    action="sketchybar --trigger windows_on_spaces"
yabai -m signal --add event=window_destroyed \
    action="sketchybar --trigger windows_on_spaces"
yabai -m signal --add event=window_moved \
    action="sketchybar --trigger windows_on_spaces"

# ── Space Setup ────────────────────────────────────────────
# Ensure desired number of spaces exist (macOS doesn't persist reliably)
DESIRED_SPACES=5
for idx in $(yabai -m query --spaces | jq '.[].index | select(. > '"$DESIRED_SPACES"')' | sort -rn); do
  yabai -m space --destroy "$idx"
done
CURRENT_SPACES=$(yabai -m query --spaces | jq 'length')
for i in $(seq $((CURRENT_SPACES + 1)) $DESIRED_SPACES); do
  yabai -m space --create
done

yabai -m space 1 --label terminal
yabai -m space 2 --label browser
yabai -m space 3 --label social
yabai -m space 4 --label design
yabai -m space 5 --label misc

# ── Auto-Launch Apps ───────────────────────────────────────
# Only launch if not already running (prevents duplicates on yabai restart)
pgrep -x "Ghostty" > /dev/null || open -a "Ghostty"
pgrep -x "Google Chrome" > /dev/null || open -a "Google Chrome"
pgrep -x "Discord" > /dev/null || open -a "Discord"

# ── Display Setup ──────────────────────────────────────────
yabai -m signal --add event=display_added action="~/.config/yabai/display_setup.sh"
yabai -m signal --add event=display_removed action="~/.config/yabai/display_setup.sh"
yabai -m signal --add event=system_woke action="~/.config/yabai/display_setup.sh"

echo "yabai configuration loaded."
