#!/bin/bash

source "$CONFIG_DIR/colors.sh"

PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"

##### Bar Appearance #####
sketchybar --bar height=36 \
  color=$BAR_COLOR \
  blur_radius=30 \
  position=top \
  sticky=on \
  padding_left=8 \
  padding_right=10 \
  shadow=on \
  display=main

##### Defaults #####
sketchybar --default \
  icon.font="SF Pro:Semibold:14.0" \
  icon.color=$ITEM_COLOR \
  label.font="$NERD_FONT:Regular:12.0" \
  label.color=$ITEM_COLOR \
  background.drawing=off \
  padding_left=4 \
  padding_right=4 \
  icon.padding_left=6 \
  icon.padding_right=3 \
  label.padding_left=3 \
  label.padding_right=6

# -- Left Side --
source $ITEM_DIR/apple.sh
$ITEM_DIR/spaces.sh init
source $ITEM_DIR/front_app.sh

# -- Center (right of notch) --
source $ITEM_DIR/playing.sh

# -- Right Side (rightmost first) --
source $ITEM_DIR/datetime.sh
source $ITEM_DIR/wifi.sh
source $ITEM_DIR/battery.sh
source $ITEM_DIR/volume.sh
source $ITEM_DIR/cpu.sh

# -- Brackets (grouped pill backgrounds) --
sketchybar --add bracket connectivity volume battery wifi \
  --set connectivity \
    background.color=$BRACKET_COLOR \
    background.corner_radius=12 \
    background.height=28 \
    background.drawing=on

##### Finalizing Setup #####
sketchybar --update
