{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "source": "~/.config/fastfetch/logo.txt",
    "type": "file",
    "color": {
      "1": "38;2;138;173;244",
      "2": "38;2;148;164;240",
      "3": "38;2;165;155;236",
      "4": "38;2;183;146;232",
      "5": "38;2;198;160;246"
    },
    "padding": {
      "top": 1,
      "left": 1,
      "right": 3
    }
  },
  "display": {
    "separator": "  ",
    "color": {
      "keys": "blue",
      "output": "white"
    }
  },
  "modules": [
    {
      "type": "title",
      "format": "{user-name-colored}{at-symbol-colored}{host-name-colored}",
      "keyColor": "blue"
    },
