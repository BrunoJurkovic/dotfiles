#!/usr/bin/env bash
#
# Pre-commit hook: scan staged files for secrets and personal data.
# Install: git config core.hooksPath .githooks

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'
FAIL=0

# Patterns to catch (case-insensitive)
PATTERNS=(
  # API keys and tokens
  'sk-[a-zA-Z0-9]{20,}'                        # OpenAI-style keys
  'ghp_[a-zA-Z0-9]{36}'                        # GitHub PAT
  'gho_[a-zA-Z0-9]{36}'                        # GitHub OAuth
  'xox[bpoas]-[a-zA-Z0-9-]+'                   # Slack tokens
  'AKIA[0-9A-Z]{16}'                           # AWS access key
  'AIza[0-9A-Za-z_-]{35}'                      # Google API key

  # Private keys
  'BEGIN (RSA |DSA |EC |OPENSSH )?PRIVATE KEY'

  # Hardcoded absolute home paths (use $HOME instead)
  '/Users/[a-zA-Z]+/'

  # Work-specific identifiers
  'valeremargins'
  'bjurkovic-margins'

  # Common secret env patterns
  'DATABASE_URL=.+'
  'DOPPLER_TOKEN=.+'
)

# Files to always skip
SKIP_PATTERN='(\.png|\.jpg|\.jpeg|\.gif|\.ico|\.woff|\.ttf|\.lock|lazy-lock\.json|\.plist)$'

echo "Scanning for secrets and personal data..."

git diff --cached --name-only --diff-filter=ACM | while IFS= read -r file; do
  # Skip binary/lock files
  [[ "$file" =~ $SKIP_PATTERN ]] && continue

  # Skip files that intentionally contain personal/work data
  [[ "$file" == ".githooks/pre-commit" ]] && continue
  [[ "$file" == "git/.config/git/work" ]] && continue

  for pattern in "${PATTERNS[@]}"; do
    if git show ":$file" 2>/dev/null | grep -qEi "$pattern"; then
      echo -e "${RED}BLOCKED${NC} $file matches: ${YELLOW}$pattern${NC}"
      git show ":$file" | grep -nEi "$pattern" | head -3 | sed 's/^/   /'
      echo "FAIL" > /tmp/dotfiles_hook_fail
    fi
  done
done

[ -f /tmp/dotfiles_hook_fail ] && FAIL=1 && rm -f /tmp/dotfiles_hook_fail

if [ "$FAIL" -eq 1 ]; then
  echo ""
  echo -e "${RED}Commit blocked.${NC} Fix the above issues or use --no-verify to bypass."
  echo "  Tip: Use \$HOME instead of /Users/username/ in configs."
  exit 1
fi

echo "Clean. No secrets detected."
